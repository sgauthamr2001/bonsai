func foo() -> bool {
  let w = true in
  let x = false in
  let y = w | x in
  let z = y & x in
  return z
}

func order_of_operations() -> i32 {
  let a = 12 in
  let b = 10 in
  let c = 6 in
  let d = 1 in
  let expect = ((a & b) ^ c) | d in
  let actual = ((a & b) ^ c) | d in
  print(expect)
  print(actual)
  return 0
}


