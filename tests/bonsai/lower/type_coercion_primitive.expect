func a(x : u32) -> u32 {
  return x + 5u
}

func b(x : f64) -> f64 {
  return x + 3
}

func c(x : f64) -> f64 {
  return x + 3
}

func d(x : f16) -> f16 {
  return x + 3h
}

func ret_f32x4(x : f32x4) -> f32x4 {
  return x + f32x4(2f)
}

func ret_fone() -> f32 {
  return 1f
}

func ret_fzero() -> f32 {
  return 0f
}

func ret_zero() -> i32 {
  return 0
}

func reti32(i : i32) -> i32 {
  return i + 2
}


