

func a(x : u32) -> u32 {
return (u32)x + (u32)5
}

func b(x : f64) -> f64 {
return (f64)x + 3
}

func c(x : f64) -> f64 {
return (f64)x + 3
}

func d(x : f16) -> f16 {
return (f16)x + 3h
}

func ret_f32x4(x : f32x4) -> f32x4 {
return (f32x4)x + x4(2f)
}

func ret_fone() -> f32 {
return cast<f32>((i32)1)
}

func ret_fzero() -> f32 {
return cast<f32>((i32)0)
}

func ret_zero() -> i32 {
return (i32)0
}

func reti32(i : i32) -> i32 {
return (i32)i + (i32)2
}


