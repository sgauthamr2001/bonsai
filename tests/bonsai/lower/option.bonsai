// option.bonsai

func make_option0(i : i32) -> option[i32] {
    return i;
}

func make_option1(i : i32) -> option[i32] {
    if (i > 0) {
        return i;
    } else {
        return {};
    }
}

func use_option(i : option[i32]) -> i32 {
    if i {
        return i;
    } else {
        return 0;
    }
}
