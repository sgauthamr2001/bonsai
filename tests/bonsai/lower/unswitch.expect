func bar() -> void {
  print(1)
  return
}

func foo() -> void {
  print(0)
  return
}

func norewrite1(a : mut bool) -> void {
  if (a) {
    foo()
    a = !a
  }
  if (a) {
    bar()
  }
  return
}

func rewrite0(a : bool, b : bool) -> void {
  if (b) {
    if (a) {
      foo()
    } else {
      bar()
    }
  }
  return
}

func rewrite1(a : bool) -> void {
  if (a) {
    foo()
    bar()
  }
  return
}


