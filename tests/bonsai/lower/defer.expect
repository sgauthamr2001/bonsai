type Float = f32
type Half = f16
type Ray = struct Ray{ o : f32x3; d : f32x3; tmax : f32 }
type vec3f = f32x3
type vec3h = f16x3

func _queued_expensive(ray : Ray, _write__alloc0 : mut i32[n], _write__i0 : i32) -> void {
  _write__alloc0[_write__i0] = cast<i32>(reduce<+>(ray.d + ray.o))
  return
}

func bounce(ray : Ray) -> Ray {
  return build<Ray>(ray.o + f32x3(rand()), ray.d + f32x3(rand()), (f32)inf)
}

func expensive(ray : Ray) -> i32 {
  return cast<i32>(reduce<+>(ray.d + ray.o))
}

func foo(ray : Ray) -> bool {
  return ray.d[0] < rand()
}

func map_hits(n : i32, rays : Ray[n]) -> i32[n] {
  exp_queue_data : mut (Ray, (i32[n]*), i32)[64]
  exp_queue : mut (u64, (Ray, (i32[n]*), i32)[64]) := (0u, exp_queue_data)
  alloc _alloc0 : mut i32[n]
  forall _i0 in [0:n:1] {
    num_hits(rays[_i0], 100, 0, _alloc0, _i0, exp_queue)
  }
  forall _exp_queue_task in [0u:exp_queue[0]:1u] {
    _queued_expensive(exp_queue[1][_exp_queue_task][0], exp_queue[1][_exp_queue_task][1], exp_queue[1][_exp_queue_task][2])
  }
  return _alloc0
}

func num_hits(ray : Ray, depth : i32, acc : i32, _write__alloc0 : mut i32[n], _write__i0 : i32, exp_queue : mut (u64, (Ray, (i32[n]*), i32)[64])) -> void {
  if (depth <= 0) {
    exp_queue[1][atomic_add((&exp_queue[0]), 1u)] = (ray, (&_write__alloc0), _write__i0)
    return
  } else if (foo(ray)) {
    num_hits(bounce(ray), depth - 1, acc + 1, _write__alloc0, _write__i0, exp_queue)
    return
  } else {
    _write__alloc0[_write__i0] = acc
    return
  }
}


schedule host {
    map_hits.make_queue(exp_queue, root, (i32)64)
    num_hits.defer(expensive, map_hits.root, exp_queue)

}
