type Ray = struct Ray{ o : f32x3; d : f32x3; t : f32 }
type Ray1 = struct Ray1{ o : f32x3; d : f32x3; t : f32 }
type Ray2 = struct Ray2{ o : f32x3; d : f32x3; t : f32 }
type Ray3 = struct Ray3{ o : f32x3; d : f32x3; t : f32 }
type vec3f = f32x3

func build_ray() -> Ray {
  return build<Ray>()
}

func build_ray1() -> Ray1 {
  return build<Ray1>()
}

func build_ray2() -> Ray2 {
  return build<Ray2>()
}

func build_ray3() -> Ray3 {
  return build<Ray3>()
}

func build_ray_params(o : f32x3, d : f32x3, t : f32) -> Ray {
  return build<Ray>(o, d, t)
}

func build_ray_params1(o : f32x3, d : f32x3) -> Ray {
  return build<Ray>(o, d, 0f)
}

func build_ray_params2(o : f32x3, d : f32x3) -> Ray {
  return build<Ray>(o, d, 0f)
}

func build_ray_params3(oall : f32, dall : f32) -> Ray {
  return build<Ray>(f32x3(oall), f32x3(dall), 0f)
}


