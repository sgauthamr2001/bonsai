func prod_diff(a : f32, b : f32, c : f32, d : f32) -> f32 {
  let cd = c * d in
  let diff = fma(a, b, -cd) in
  let err = fma(-c, d, cd) in
  return diff + err
}

func sqlen(v : f32x3) -> f32 {
  return reduce<+>(v * v)
}

