func intersects_Ray_AABB(r : Ray, b : AABB) -> bool {
  let interval = intersectsp_ray_aabb(r, b) in
  if (interval.set) {
    let extract = interval.value in
    return (extract.low < r.t) && (0f < extract.high)
  }
  return false
}

func intersects_Ray_Triangle(ray : Ray, tri : Triangle) -> bool {
