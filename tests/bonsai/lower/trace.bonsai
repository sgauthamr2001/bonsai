import stdlib/distance;
import stdlib/intersects;
import stdlib/triangle;

extern triangles : set[Triangle];

func [[export]] trace(ray : Ray) = argmin(|tri| distmin(ray, tri), filter(|tri| intersects(ray, tri), triangles));

func [[export]] trace_all(n : u32, rays : array[Ray, n]) = map(|r : Ray| trace(r), rays);

// func alltrace(ray : Ray) = filter(|tri| intersects(ray, tri), triangles);


schedule {
    // TODO: generic over primitive types!
    tree[[Triangle]] TriangleBVH(low high : vec3f) with AABB(low, high) =
    | Interior(left : TriangleBVH, right : TriangleBVH, axis : u8)
    | Leaf(data : array[Triangle]);

    triangles : TriangleBVH;

    layout triangles {
        pCount : u32;
        prims : array[Triangle, pCount];
        count : u32;
        group[count] index : u32 {
            low : vec3f;
            nPrims : u16;
            axis : u8;
            8; // pad bits.
            high : vec3f;
            switch nPrims {
                0 => Interior { offset : u32; left = index + 1; right = index + offset; };
                _ => Leaf { pOffset : u32; data = range(prims, pOffset, cast[[u32]](nPrims)); };
            };
        };
    };

    trace.sort(triangles.Interior, |i : u8, ray : Ray, axis : u8| select((1 / ray.d)[axis] < 0, 1 - i, i))
         .loopify(64);
}


