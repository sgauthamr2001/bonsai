import tests/bonsai/lower/intersects;

extern triangles : set[Triangle];

// func trace(ray : Ray) = argmin(|tri| distance(ray, tri), filter(|tri| intersects(ray, tri), triangles));

func alltrace(ray : Ray) = filter(|tri| intersects(ray, tri), triangles);


schedule {
    // TODO: generic over primitive types!
    tree[[Triangle]] TriangleBVH(low high : vec3f) with AABB(low, high) =
    | Interior(left : TriangleBVH, right : TriangleBVH)
    | Leaf(data : array[Triangle]);

    triangles : TriangleBVH;

    layout triangles {
        pCount : u32;
        prims : array[Triangle, pCount];
        count : u32;
        group[count] index : u32 {
            low : vec3f;
            nPrims : u16;
            axis : u8;
            8; // pad bits.
            high : vec3f;
            switch nPrims {
                0 => { offset : u32; left = index + 1; right = index + offset; };
                _ => { pOffset : u32; data = range(prims, pOffset, nPrims); };
            };
        };
    };
}


