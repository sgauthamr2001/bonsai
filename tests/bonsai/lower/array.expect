func _traverse_array0(fs : i32[8]) -> i32[8] {
  _alloc0 := build<i32[8]>()
  forall _i0 in [0:8:1] {
    _alloc0[_i0] = f(fs[_i0]) + 1
  }
  return _alloc0
}

func _traverse_array1(xs : i32[3]) -> i32[3] {
  _alloc1 := build<i32[3]>()
  forall _i0 in [0:3:1] {
    _alloc1[_i0] = xs[_i0] + 1
  }
  return _alloc1
}

func _traverse_array2(ij : i32[4][8]) -> i32[4][8] {
  _alloc2 := build<i32[8 * 4]>()
  forall _i0 in [0:8:1] {
    forall _i1 in [0:4:1] {
      _alloc2[(_i0 << 2) + _i1] = ij[_i0][_i1] + 1
    }
  }
  return cast<i32[4][8]>(_alloc2)
}

func _traverse_array3(ijk : i32[32][16][8]) -> i32[32][16][8] {
  _alloc3 := build<i32[(8 * 16) * 32]>()
  forall _i0 in [0:8:1] {
    forall _i1 in [0:16:1] {
      forall _i2 in [0:32:1] {
        _alloc3[(((_i0 << 4) + _i1) << 5) + _i2] = ijk[_i0][_i1][_i2] + 1
      }
    }
  }
  return cast<i32[32][16][8]>(_alloc3)
}

func _traverse_array4(ij : i32[8][8]) -> i32[8][8] {
  _alloc4 := build<i32[8 * 8]>()
  forall _i0 in [0:8:1] {
    forall _i1 in [0:8:1] {
      _alloc4[(_i0 << 3) + _i1] = (ij[_i0][_i1] + 1) - 1
    }
  }
  return cast<i32[8][8]>(_alloc4)
}

func _traverse_array5(xs : i32[8]) -> i32[8] {
  _alloc5 := build<i32[8]>()
  forall _i0 in [0:8:1] {
    _alloc5[_i0] = ((xs[_i0] << 1) - 1) + 1
  }
  return _alloc5
}

func apply_function(fs : i32[8]) -> i32[8] {
  return _traverse_array0(fs)
}

func f(x : i32) -> i32 {
  return x
}

func local() -> i32[3] {
  let xs = build<i32[3]>(1, 2, 3) in
  return _traverse_array1(build<i32[3]>(1, 2, 3))
}

func tall1(ij : i32[4][8]) -> i32[4][8] {
  return _traverse_array2(ij)
}

func tall2(ijk : i32[32][16][8]) -> i32[32][16][8] {
  return _traverse_array3(ijk)
}

func tall_and_wide(ij : i32[8][8]) -> i32[8][8] {
  return _traverse_array4(ij)
}

func wide(xs : i32[8]) -> i32[8] {
  return _traverse_array5(xs)
}


