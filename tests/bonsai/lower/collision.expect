func axis(A : f32x3, extents : f32x3, v0 : f32x3, v1 : f32x3, v2 : f32x3) -> bool {
  let R = dot(extents, abs(A)) in
  let P = build<f32x3>(dot(v0, A), dot(v1, A), dot(v2, A)) in
  return reduce<all>((P <= f32x3(R)) & (f32x3(-R) <= P))
}

