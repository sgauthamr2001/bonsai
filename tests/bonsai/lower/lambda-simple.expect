

func ?lambda0(x : i32) -> i32 {
  return x + (i32)1
}

func ?lambda1(x : i32) -> i32 {
  return x - (i32)1
}

func foo() -> i32 {
  let L1 = |x : i32| x + (i32)1 in
  let y = ?lambda0((i32)0) in
  return y
}

func main() -> i32 {
  let L1 = |x : i32| x - (i32)1 in
  let y = ?lambda1((i32)0) in
  return y
}

func relu(v : set<i32>) -> set<i32> {
  return filter(|x : i32| (i32)0 < x, v)
}


