element Float = f32;
element vec3f = vector[Float, 3];

element Triangle {
    p0, p1, p2 : vec3f;
}

element AABB {
    low, high : vec3f;
}

extern tris : set[Triangle];

schedule {
    tree[[Triangle]] TriangleBVH(low high : vec3f) with AABB(low, high) =
    | Interior(left : TriangleBVH, right : TriangleBVH)
    | Leaf(data : Triangle);

    tree[[Triangle]] TriangleBVH1 =
    | Interior(left : TriangleBVH1, right : TriangleBVH1, low high : vec3f) with AABB(low, high)
    | Leaf(data : Triangle, low high : vec3f);

    tris : TriangleBVH;
}
