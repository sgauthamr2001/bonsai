element Float = f32;
element vec3f = vector[Float, 3];

element Triangle {
    p0, p1, p2 : vec3f;
}

element AABB {
    low, high : vec3f;
}

tree TriangleBVH(low high : vec3f) with AABB(low, high) =
| Interior(left : ptr, right : ptr)
| Leaf(data : Triangle, low high : vec3f);

tree TriangleBVH1 =
| Interior(left : ptr, right : ptr, low high : vec3f) with AABB(low, high)
| Leaf(data : Triangle, low high : vec3f);

