type ?triangles_layout0 = struct ?triangles_layout0{ low : f32x3; nPrims : u16; axis : u8; ?pad0 : u8; high : f32x3; triangles_?spliton_nPrims : u8x4 }
type ?triangles_layout1 = struct ?triangles_layout1{ pCount : u32; prims : struct Triangle{ p0 : f32x3; p1 : f32x3; p2 : f32x3 }[pCount]; count : u32; triangles_index : struct ?triangles_layout0{ low : f32x3; nPrims : u16; axis : u8; ?pad0 : u8; high : f32x3; triangles_?spliton_nPrims : u8x4 }[count] }
