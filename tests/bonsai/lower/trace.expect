type AABB = struct AABB{ low : f32x3; high : f32x3 }
type FInterval = struct FInterval{ low : f32; high : f32 }
type Float = f32
type Half = f16
type Point = struct Point{ vec : f32x3 }
type Ray = struct Ray{ o : f32x3; d : f32x3; t : f32 }
type Triangle = struct Triangle{ p0 : f32x3; p1 : f32x3; p2 : f32x3 }
type TriangleBVH = (const TriangleBVH&)
type TriangleIntersection = struct TriangleIntersection{ b0 : f32; b1 : f32; b2 : f32; t : f32 }
type _triangles_layout0 = struct _triangles_layout0{ low : f32x3; nPrims : u16; axis : u8; _pad0 : u8; high : f32x3; triangles_spliton_nPrims : u8x4 }
type _triangles_layout1 = struct _triangles_layout1{ pCount : u32; prims : struct Triangle{ p0 : f32x3; p1 : f32x3; p2 : f32x3 }[pCount]; count : u32; triangles_index : struct _triangles_layout0{ low : f32x3; nPrims : u16; axis : u8; _pad0 : u8; high : f32x3; triangles_spliton_nPrims : u8x4 }[count] }
type vec3f = f32x3
type vec3h = f16x3

extern triangles : struct _triangles_layout1{ pCount : u32; prims : struct Triangle{ p0 : f32x3; p1 : f32x3; p2 : f32x3 }[pCount]; count : u32; triangles_index : struct _triangles_layout0{ low : f32x3; nPrims : u16; axis : u8; _pad0 : u8; high : f32x3; triangles_spliton_nPrims : u8x4 }[count] }

func _traverse_array0(n : u32, rays : Ray[n], triangles : _triangles_layout1) -> Triangle[n] {
  alloc _alloc0 : Triangle[n]
  forall r in [0u:n:1u] {
    let _load0 = rays[r] in
    _alloc0[r] = _traverse_tree0(_load0, triangles)
  }
  return _alloc0
}

func _traverse_tree0(ray : Ray, triangles : _triangles_layout1) -> Triangle {
  _best0 := build<tuple.0>((f32)inf, build<Triangle>())
  rec(triangles__index : u32) {
    if (intersects_Ray_AABB(ray, build<AABB>(triangles.triangles_index[triangles__index].low, triangles.triangles_index[triangles__index].high)) && (distmin_Ray_AABB(ray, build<AABB>(triangles.triangles_index[triangles__index].low, triangles.triangles_index[triangles__index].high)) < _best0._field0)) {
      if (triangles.triangles_index[triangles__index].nPrims == 0u) {
        from triangles__index + 1u
        from triangles__index + cast<__layout6>(triangles.triangles_index[triangles__index].triangles_spliton_nPrims).offset
      } else {
        forall _idx0 in [0u:cast<u32>(triangles.triangles_index[triangles__index].nPrims):1u] {
          let _iter0 = triangles.prims[cast<__layout9>(triangles.triangles_index[triangles__index].triangles_spliton_nPrims).pOffset + _idx0] in
          if (intersectsp_ray_tri(ray, _iter0).set && (distmin_Ray_Triangle(ray, _iter0) < _best0._field0)) {
            _best0 argmin= build<tuple.0>(distmin_Ray_Triangle(ray, _iter0), _iter0)
          }
        }
      }
    }
  }
  return _best0._field1
}

func _unexported_trace(ray : Ray, triangles : _triangles_layout1) -> Triangle {
  return _traverse_tree0(ray, triangles)
}

func distmax_Ray_AABB(r : Ray, b : AABB) -> f32 {
  let interval = intersectsp_ray_aabb(r, b) in
  if (interval.set) {
    let extract = interval.value in
    return extract.high
  }
  return (f32)inf
}

func distmin_Point_AABB(pt : Point, a : AABB) -> f32 {
  return sqrt(SqDistPointAABB(pt, a))
}

func distmin_Point_Triangle(p : Point, tri : Triangle) -> f32 {
  let pts = closestPointonTriangle(p, tri) in
  return norm(p.vec - pts._field0.vec)
}

func distmin_Ray_AABB(r : Ray, b : AABB) -> f32 {
  let interval = intersectsp_ray_aabb(r, b) in
  if (interval.set) {
    let extract = interval.value in
    return extract.low
  }
  return -(f32)inf
}

func distmin_Ray_Triangle(ray : Ray, tri : Triangle) -> f32 {
  let isect = intersectsp_ray_tri(ray, tri) in
  if (isect.set) {
    let isect_ = isect.value in
    return isect_.t
  } else {
    return (f32)inf
  }
}

func intersects_Ray_AABB(r : Ray, b : AABB) -> bool {
  let interval = intersectsp_ray_aabb(r, b) in
  if (interval.set) {
    let extract = interval.value in
    return (extract.low < r.t) && (0f < extract.high)
  }
  return false
}

func intersects_Ray_Triangle(ray : Ray, tri : Triangle) -> bool {
  return intersectsp_ray_tri(ray, tri).set
}

func [[export]] trace(_ret0 : mut Triangle, ray : Ray, triangles : _triangles_layout1) -> void {
  _ret0 = _traverse_tree0(ray, triangles)
  return
}

func [[export]] trace_all(n : u32, rays : Ray[n], triangles : _triangles_layout1) -> Triangle[n] {
  return _traverse_array0(n, rays, triangles)
}


