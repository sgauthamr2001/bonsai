func intersects_Ray_AABB(r : (Ray*), b : (AABB*)) -> bool {
  let interval = intersectsp_ray_aabb(r, b) in
  if (interval.set) {
    let extract = interval.value in
    return (extract.low < (*r).tmax) & (0f < extract.high)
  }
  return false
}

func intersects_Ray_Sphere(ray : (Ray*), s : (Sphere*)) -> bool {
  let interval = intersectsp_ray_sphere(ray, s) in
  if (interval.set) {
