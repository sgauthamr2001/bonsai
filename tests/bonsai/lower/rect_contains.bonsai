//! flags: -p lower-trees -p lower-geometrics

element Float = f32;
element vec3f = vector[Float, 3];

element AABB {
    low, high : vec3f;
}

element Point {
    data : vec3f;
}

func contains(r : AABB, p : Point) -> bool {
    return all(p.data >= r.low & p.data <= r.high);
}

func contains(a : AABB, b : AABB) -> bool {
    return all(a.low <= b.low & a.high >= b.high);
}

func intersects(a : AABB, b : AABB) -> bool {
    low = max(a.low, b.low);
    high = min(a.high, b.high);
    return all(low <= high);
}

extern points : set[Point];

func query(r : AABB) = filter(|p| contains(r, p), points);

schedule {
    // TODO: generic over primitive types!
    tree[[Point]] PointBVH(low high : vec3f) with AABB(low, high) =
    | Interior(left : PointBVH, right : PointBVH)
    | Leaf(data : Point) with data = data;

    points : PointBVH;
}
