func foo() {
    print(0);
    return;
}

func bar() {
    print(1);
    return;
}

// TODO(ajr): these tests would be easier to write if we had parsing support for CallStmt
func rewrite0(a : bool, b : bool) {
    if (a) {
        if (b) { foo(); }
    } else {
        if (b) { bar(); }
    }
    return;
}

func rewrite1(a : bool) {
    if (a) { foo(); }
    if (a) { bar(); }
    return;
}

func norewrite1(a : mut bool) {
    if (a) {
        foo();
        a = !a;
    }
    if (a) {
        bar();
    }
    return;
}


