type AABB = struct AABB{ low : f32x3; high : f32x3 }
type Float = f32
type Ray = struct Ray{ o : f32x3; d : f32x3; t : f32 }
type Triangle = struct Triangle{ p0 : f32x3; p1 : f32x3; p2 : f32x3 }
type TriangleBVH = (const TriangleBVH&)
type vec3f = f32x3

extern triangles : tree[[struct Triangle{ p0 : f32x3; p1 : f32x3; p2 : f32x3 }]] TriangleBVH
  | Interior(low : f32x3, high : f32x3, left : (const TriangleBVH&), right : (const TriangleBVH&)) with AABB(low, high)
  | Leaf(low : f32x3, high : f32x3, data : Triangle) with AABB(low, high)
extern triangles2 : tree[[struct Triangle{ p0 : f32x3; p1 : f32x3; p2 : f32x3 }]] TriangleBVH
  | Interior(low : f32x3, high : f32x3, left : (const TriangleBVH&), right : (const TriangleBVH&)) with AABB(low, high)
  | Leaf(low : f32x3, high : f32x3, data : Triangle) with AABB(low, high)

func _traverse_tree0(ray : Ray, triangles : tree[[Triangle]] TriangleBVH) -> set<Triangle> {
  match triangles {
  | Interior(low : f32x3, high : f32x3, left : (const TriangleBVH&), right : (const TriangleBVH&)) with AABB(low, high) ->
    if (intersects(ray, build<AABB>((triangles as Interior).low, (triangles as Interior).high))) {
      from (triangles as Interior).left
    }
    if (intersects(ray, build<AABB>((triangles as Interior).low, (triangles as Interior).high))) {
      from (triangles as Interior).right
    }
  | Leaf(low : f32x3, high : f32x3, data : Triangle) with AABB(low, high) ->
    if (intersects(ray, build<AABB>((triangles as Leaf).low, (triangles as Leaf).high))) {
      if (intersects(ray, (triangles as Leaf).data)) {
        yield (triangles as Leaf).data
      }
    }
  }
}

func _traverse_tree1(triangles : tree[[Triangle]] TriangleBVH, triangles2 : tree[[Triangle]] TriangleBVH) -> set<(Triangle, Triangle)> {
  match triangles {
  | Interior(low : f32x3, high : f32x3, left : (const TriangleBVH&), right : (const TriangleBVH&)) with AABB(low, high) ->
    match triangles2 {
    | Interior(low : f32x3, high : f32x3, left : (const TriangleBVH&), right : (const TriangleBVH&)) with AABB(low, high) ->
      if (intersects(build<AABB>((triangles as Interior).low, (triangles as Interior).high), build<AABB>((triangles2 as Interior).low, (triangles2 as Interior).high))) {
        from build<((const TriangleBVH&), (const TriangleBVH&))>((triangles as Interior).left, (triangles2 as Interior).left)
      }
      if (intersects(build<AABB>((triangles as Interior).low, (triangles as Interior).high), build<AABB>((triangles2 as Interior).low, (triangles2 as Interior).high))) {
        from build<((const TriangleBVH&), (const TriangleBVH&))>((triangles as Interior).left, (triangles2 as Interior).right)
      }
    | Leaf(low : f32x3, high : f32x3, data : Triangle) with AABB(low, high) ->
      if (intersects(build<AABB>((triangles as Interior).low, (triangles as Interior).high), build<AABB>((triangles2 as Leaf).low, (triangles2 as Leaf).high))) {
        from build<((const TriangleBVH&), Triangle)>((triangles as Interior).left, (triangles2 as Leaf).data)
      }
    }
    match triangles2 {
    | Interior(low : f32x3, high : f32x3, left : (const TriangleBVH&), right : (const TriangleBVH&)) with AABB(low, high) ->
      if (intersects(build<AABB>((triangles as Interior).low, (triangles as Interior).high), build<AABB>((triangles2 as Interior).low, (triangles2 as Interior).high))) {
        from build<((const TriangleBVH&), (const TriangleBVH&))>((triangles as Interior).right, (triangles2 as Interior).left)
      }
      if (intersects(build<AABB>((triangles as Interior).low, (triangles as Interior).high), build<AABB>((triangles2 as Interior).low, (triangles2 as Interior).high))) {
        from build<((const TriangleBVH&), (const TriangleBVH&))>((triangles as Interior).right, (triangles2 as Interior).right)
      }
    | Leaf(low : f32x3, high : f32x3, data : Triangle) with AABB(low, high) ->
      if (intersects(build<AABB>((triangles as Interior).low, (triangles as Interior).high), build<AABB>((triangles2 as Leaf).low, (triangles2 as Leaf).high))) {
        from build<((const TriangleBVH&), Triangle)>((triangles as Interior).right, (triangles2 as Leaf).data)
      }
    }
  | Leaf(low : f32x3, high : f32x3, data : Triangle) with AABB(low, high) ->
    match triangles2 {
    | Interior(low : f32x3, high : f32x3, left : (const TriangleBVH&), right : (const TriangleBVH&)) with AABB(low, high) ->
      if (intersects(build<AABB>((triangles as Leaf).low, (triangles as Leaf).high), build<AABB>((triangles2 as Interior).low, (triangles2 as Interior).high))) {
        from build<(Triangle, (const TriangleBVH&))>((triangles as Leaf).data, (triangles2 as Interior).left)
      }
      if (intersects(build<AABB>((triangles as Leaf).low, (triangles as Leaf).high), build<AABB>((triangles2 as Interior).low, (triangles2 as Interior).high))) {
        from build<(Triangle, (const TriangleBVH&))>((triangles as Leaf).data, (triangles2 as Interior).right)
      }
    | Leaf(low : f32x3, high : f32x3, data : Triangle) with AABB(low, high) ->
      if (intersects(build<AABB>((triangles as Leaf).low, (triangles as Leaf).high), build<AABB>((triangles2 as Leaf).low, (triangles2 as Leaf).high))) {
        if (intersects(build<(Triangle, Triangle)>((triangles as Leaf).data, (triangles2 as Leaf).data)[0], build<(Triangle, Triangle)>((triangles as Leaf).data, (triangles2 as Leaf).data)[1])) {
          yield build<(Triangle, Triangle)>((triangles as Leaf).data, (triangles2 as Leaf).data)
        }
      }
    }
  }
}

func _traverse_tree2(ray : Ray, triangles : tree[[Triangle]] TriangleBVH) -> option<Triangle> {
  _best0 : mut (f32, Triangle) := build<(f32, Triangle)>((f32)inf, build<Triangle>())
  match triangles {
  | Interior(low : f32x3, high : f32x3, left : (const TriangleBVH&), right : (const TriangleBVH&)) with AABB(low, high) ->
    if (intersects(ray, build<AABB>((triangles as Interior).low, (triangles as Interior).high)) && (distmin(ray, build<AABB>((triangles as Interior).low, (triangles as Interior).high)) < _best0[0])) {
      from (triangles as Interior).left
    }
    if (intersects(ray, build<AABB>((triangles as Interior).low, (triangles as Interior).high)) && (distmin(ray, build<AABB>((triangles as Interior).low, (triangles as Interior).high)) < _best0[0])) {
      from (triangles as Interior).right
    }
  | Leaf(low : f32x3, high : f32x3, data : Triangle) with AABB(low, high) ->
    if (intersects(ray, build<AABB>((triangles as Leaf).low, (triangles as Leaf).high)) && (distmin(ray, build<AABB>((triangles as Leaf).low, (triangles as Leaf).high)) < _best0[0])) {
      if (intersects(ray, (triangles as Leaf).data) && (distmin(ray, (triangles as Leaf).data) < _best0[0])) {
        _best0 argmin= build<(f32, Triangle)>(distmin(ray, (triangles as Leaf).data), (triangles as Leaf).data)
      }
    }
  }
  yield select(_best0[0] != (f32)inf, build<option<Triangle>>(_best0[1]), build<option<Triangle>>())
}

func alltrace(ray : Ray) -> set<Triangle> {
  return _traverse_tree0(ray, triangles)
}

func collisions() -> set<(Triangle, Triangle)> {
  return _traverse_tree1(triangles, triangles2)
}

func trace(ray : Ray) -> option<Triangle> {
  return _traverse_tree2(ray, triangles)
}


schedule host{
}
