type AABB = struct AABB{ low : f32x3; high : f32x3 }
type Float = f32
type Ray = struct Ray{ o : f32x3; d : f32x3; t : f32 }
type Triangle = struct Triangle{ p0 : f32x3; p1 : f32x3; p2 : f32x3 }
type vec3f = f32x3

extern triangles : tree[[struct Triangle{ p0 : f32x3; p1 : f32x3; p2 : f32x3 }]] TriangleBVH
  | Interior(low : f32x3, high : f32x3, left : (struct TriangleBVH{  }*), right : (struct TriangleBVH{  }*)) with AABB(low, high)
  | Leaf(low : f32x3, high : f32x3, data : struct Triangle{ p0 : f32x3; p1 : f32x3; p2 : f32x3 }, low : f32x3, high : f32x3) with AABB(low, high)
extern triangles2 : tree[[struct Triangle{ p0 : f32x3; p1 : f32x3; p2 : f32x3 }]] TriangleBVH
  | Interior(low : f32x3, high : f32x3, left : (struct TriangleBVH{  }*), right : (struct TriangleBVH{  }*)) with AABB(low, high)
  | Leaf(low : f32x3, high : f32x3, data : struct Triangle{ p0 : f32x3; p1 : f32x3; p2 : f32x3 }, low : f32x3, high : f32x3) with AABB(low, high)

func ?traverse0(ray : Ray, triangles : tree[[Triangle]] TriangleBVH) -> set<Triangle> {
  match triangles{
  | Interior(low : f32x3, high : f32x3, left : (TriangleBVH*), right : (TriangleBVH*)) with AABB(low, high) ->
    if (intersects(ray, triangles.volume)) {
      from triangles.left
    }
    if (intersects(ray, triangles.volume)) {
      from triangles.right
    }
  | Leaf(low : f32x3, high : f32x3, data : Triangle, low : f32x3, high : f32x3) with AABB(low, high) ->
    if (intersects(ray, triangles.volume)) {
      if (intersects(ray, triangles.data)) {
        yield triangles.data
      }
    }
  }
}

func ?traverse1(triangles : tree[[Triangle]] TriangleBVH, triangles2 : tree[[Triangle]] TriangleBVH) -> set<(Triangle, Triangle)> {
  match triangles{
  | Interior(low : f32x3, high : f32x3, left : (TriangleBVH*), right : (TriangleBVH*)) with AABB(low, high) ->
    match triangles2{
    | Interior(low : f32x3, high : f32x3, left : (TriangleBVH*), right : (TriangleBVH*)) with AABB(low, high) ->
      if (intersects(triangles.volume, triangles2.volume)) {
        from build<(tree[[Triangle]] TriangleBVH, tree[[Triangle]] TriangleBVH)>(triangles.left, triangles2.left)
      }
      if (intersects(triangles.volume, triangles2.volume)) {
        from build<(tree[[Triangle]] TriangleBVH, tree[[Triangle]] TriangleBVH)>(triangles.left, triangles2.right)
      }
    | Leaf(low : f32x3, high : f32x3, data : Triangle, low : f32x3, high : f32x3) with AABB(low, high) ->
      if (intersects(triangles.volume, triangles2.volume)) {
        from build<(tree[[Triangle]] TriangleBVH, Triangle)>(triangles.left, triangles2.data)
      }
    }
    match triangles2{
    | Interior(low : f32x3, high : f32x3, left : (TriangleBVH*), right : (TriangleBVH*)) with AABB(low, high) ->
      if (intersects(triangles.volume, triangles2.volume)) {
        from build<(tree[[Triangle]] TriangleBVH, tree[[Triangle]] TriangleBVH)>(triangles.right, triangles2.left)
      }
      if (intersects(triangles.volume, triangles2.volume)) {
        from build<(tree[[Triangle]] TriangleBVH, tree[[Triangle]] TriangleBVH)>(triangles.right, triangles2.right)
      }
    | Leaf(low : f32x3, high : f32x3, data : Triangle, low : f32x3, high : f32x3) with AABB(low, high) ->
      if (intersects(triangles.volume, triangles2.volume)) {
        from build<(tree[[Triangle]] TriangleBVH, Triangle)>(triangles.right, triangles2.data)
      }
    }
  | Leaf(low : f32x3, high : f32x3, data : Triangle, low : f32x3, high : f32x3) with AABB(low, high) ->
    match triangles2{
    | Interior(low : f32x3, high : f32x3, left : (TriangleBVH*), right : (TriangleBVH*)) with AABB(low, high) ->
      if (intersects(triangles.volume, triangles2.volume)) {
        from build<(Triangle, tree[[Triangle]] TriangleBVH)>(triangles.data, triangles2.left)
      }
      if (intersects(triangles.volume, triangles2.volume)) {
        from build<(Triangle, tree[[Triangle]] TriangleBVH)>(triangles.data, triangles2.right)
      }
    | Leaf(low : f32x3, high : f32x3, data : Triangle, low : f32x3, high : f32x3) with AABB(low, high) ->
      if (intersects(triangles.volume, triangles2.volume)) {
        if (intersects(build<(Triangle, Triangle)>(triangles.data, triangles2.data)[(i32)0], build<(Triangle, Triangle)>(triangles.data, triangles2.data)[(i32)1])) {
          yield build<(Triangle, Triangle)>(triangles.data, triangles2.data)
        }
      }
    }
  }
}

func ?traverse2(ray : Ray, triangles : tree[[Triangle]] TriangleBVH) -> Triangle {
  ?best0 := build<(f32, Triangle)>((f32)inf, build<Triangle>())
  match triangles{
  | Interior(low : f32x3, high : f32x3, left : (TriangleBVH*), right : (TriangleBVH*)) with AABB(low, high) ->
    if (intersects(ray, triangles.volume)) {
      from triangles.left
    }
    if (intersects(ray, triangles.volume)) {
      from triangles.right
    }
  | Leaf(low : f32x3, high : f32x3, data : Triangle, low : f32x3, high : f32x3) with AABB(low, high) ->
    if (intersects(ray, triangles.volume)) {
      if (intersects(ray, triangles.data)) {
        if (distance(ray, triangles.volume) < ?best0[(i32)0]) {
          let ?best0_temp0 = distance(ray, triangles.data) in
          if (?best0_temp0 < ?best0[(i32)0]) {
            ?best0 = build<(f32, Triangle)>(?best0_temp0, triangles.data)
          }
        }
      }
    }
  }
  yield ?best0[(i32)1]
}

func alltrace(ray : Ray) -> set<Triangle> {
  return ?traverse0(ray, triangles)
}

func collisions() -> set<(Triangle, Triangle)> {
  return ?traverse1(triangles, triangles2)
}

func trace(ray : Ray) -> Triangle {
  return ?traverse2(ray, triangles)
}


schedule host{
}
