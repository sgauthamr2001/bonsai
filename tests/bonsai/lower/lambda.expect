

func foo() -> i32 {
  let a = true in
  let b = false in
  let c = (a || b) || false in
  let d = true || b in
  let L1 = |x : i32| x + (i32)1 in
  let L2 = |x : i32, y : i32| (x + (i32)1) + y in
  let L3 = |e : bool, f : bool| e || f in
  let L4 = |e : bool, f : bool| e || f in
  let L5 = |y : i32| y in
  let L6 = |x : i32, y : i32| x + y in
  let L7 = |x : i32| |y : i32| y in
  return L1((i32)0)
}

func relu(v : set<i32>) -> set<i32> {
  return filter(|x : i32| (i32)0 < x, v)
}


