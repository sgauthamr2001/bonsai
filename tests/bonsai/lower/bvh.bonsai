//! flags: -p canonicalize -p lower-trees

element Float = f32;
element vec3f = vector[Float, 3];

element Ray {
    o : vec3f;
    d : vec3f;
    t : Float = 0;
    // TODO: medium
    // TODO: differential?
}

element Triangle {
    p0, p1, p2 : vec3f;
}

element AABB {
    low, high : vec3f;
}

extern triangles : set[Triangle];

func trace(ray : Ray) = argmin(|tri| distmin(ray, tri), filter(|tri| intersects(ray, tri), triangles));

func alltrace(ray : Ray) = filter(|tri| intersects(ray, tri), triangles);

extern triangles2 : set[Triangle];

func collisions() = filter(|t0 t1| intersects(t0, t1), product(triangles, triangles2));

schedule {
    // TODO: generic over primitive types!
    tree[[Triangle]] TriangleBVH(low high : vec3f) with AABB(low, high) =
    | Interior(left : TriangleBVH, right : TriangleBVH)
    | Leaf(data : Triangle);

    triangles : TriangleBVH;
    triangles2 : TriangleBVH;
}
