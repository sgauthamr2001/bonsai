element Float = f32;

element Ray {
    o : vector[Float, 3];
    d : vector[Float, 3];
    t : Float = 0;
    // TODO: medium
    // TODO: differential?
}

element Triangle {
    p0, p1, p2 : vector[Float, 3];
}

extern triangles : set[Triangle];

func trace(ray : Ray) = argmin(|tri| distance(ray, tri), filter(|tri| intersects(ray, tri), triangles));
