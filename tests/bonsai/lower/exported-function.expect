type Position = struct Position{ x : i32; y : i32; z : i32; c : f32 }

func [[export]] foo(_ret0 : mut Position, i : Position, j : Position) -> void {
  _ret0 = build<Position>(i.x + j.x, i.y + j.y, i.z + j.z, i.c + j.c)
  return
}

func id(x : Position) -> Position {
  return x
}

func main() -> i32 {
  let i = build<Position>(1, 2, 3, 1f) in
  let j = build<Position>(10, 20, 30, 41f) in
  r1 := build<Position>()
  foo(r1, i, j)
  let r2 = id(r1) in
  return 0
}


