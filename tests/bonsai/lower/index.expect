func first(v : f32x3) -> f32 {
  return v[0]
}

func idx(v : f32x3, i : u32) -> f32 {
  return v[i]
}

func safe_idx(v : f32x3, i : i32) -> f32 {
  if ((0 <= i) && (i < 3)) {
    return v[i]
  } else {
    return 0f
  }
}

func safe_oob(v : f32x3) -> f32 {
  return safe_idx(v, 4)
}

func second(v : f32x3) -> f32 {
  return v[1]
}

func third(v : f32x3) -> f32 {
  return v[2]
}


