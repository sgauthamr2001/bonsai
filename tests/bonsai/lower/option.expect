func make_option0(i : i32) -> _option0 {
  return build<_option0>(i, true)
}

func make_option1(i : i32) -> _option0 {
  if (0 < i) {
    return build<_option0>(i, true)
  } else {
    return build<_option0>()
  }
}

func use_option(i : _option0) -> i32 {
  if (i.set) {
    return i.value
  } else {
    return 0
  }
}

func use_option1(i : _option0) -> i32 {
  if (i.set) {
    return i.value + 10
  } else {
    return 0
  }
}


