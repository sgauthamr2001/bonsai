//! flags: -p core

element Position { x: i32; y: i32; z: i32; c: f32; }

func [[export]] foo(i: Position, j: Position) -> Position {
  return Position {i.x + j.x, i.y + j.y, i.z + j.z, i.c + j.c };
}

func id(x: Position) -> Position { return x; }

func main() -> i32 {
  i: Position = Position {1,  2,  3,  1.0};
  j: Position = Position {10, 20, 30, 41.0};
  r1: Position = foo(i, j);
  r2: Position = id(r1);
  return 0;
}
