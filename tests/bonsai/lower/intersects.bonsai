element Float = f32;
element vec3f = vector[Float, 3];

// TODO: generics
func sqlen(v : vector[Float, 3]) -> Float = sum(v * v);

// TODO: implement generics!
func prod_diff(a : Float, b : Float, c : Float, d : Float) -> Float {
    cd = c * d;
    diff = fma(a, b, -cd);
    err = fma(-c, d, cd);
    return diff + err;
}

func cross_(v0 : vector[Float, 3], v1 : vector[Float, 3]) -> vector[Float, 3] {
    return {prod_diff(v0.y, v1.z, v0.z, v1.y), prod_diff(v0.z, v1.x, v0.x, v1.z), prod_diff(v0.x, v1.y, v0.y, v1.x)};
}

element Ray {
    o : vec3f;
    d : vec3f;
    t : Float = 0;
    // TODO: medium
    // TODO: differential?
}

element Triangle {
    p0, p1, p2 : vec3f;
}

element AABB {
    low, high : vec3f;
}

// TODO: generic over F : IFloat
func gamma(n : i32) -> Float = (cast[[Float]](n) * eps[[Float]]()) / (1 - cast[[Float]](n) * eps[[Float]]());

element FInterval {
    low, high : Float;
}

func intersectsp_ray_aabb(r : Ray, b : AABB) -> option[FInterval] {
    invDir = 1 / r.d;
    dirIsNeg = invDir < 0;

    // Check for ray intersection against slabs.
    low_parts = select(dirIsNeg, b.low, b.high);
    high_parts = select(dirIsNeg, b.high, b.low);
    tMin : mut = (low_parts - r.o) * invDir;
    tMax : mut = (high_parts - r.o) * invDir;

    // Update to ensure robust bounds intersection
    tMax *= 1 + 2 * gamma(3);

    if (tMin.x > tMax.y || tMin.y > tMax.x) {
        return {}; // false
    }

    tmin : mut = max(tMin.x, tMin.y); // TODO: handle inf/nan behavior
    tmax : mut = min(tMax.x, tMax.y); // TODO: handle inf/nan behavior

    if (tmin > tMax.z || tMin.z > tmax) {
        return {}; // false
    }

    tmin = max(tmin, tMin.z); // TODO: handle inf/nan behavior
    tmax = min(tmax, tMax.z); // TODO: handle inf/nan behavior

    return FInterval{tmin, tmax};
//    return (tmin < r.t) && (tmax > 0);
}

func intersects(r : Ray, b : AABB) -> bool {
    interval = intersectsp_ray_aabb(r, b);
    if interval {
        extract = *interval;
        return extract.low < r.t && extract.high > 0;
    }
    return false;
}

func distmax(r : Ray, b : AABB) -> Float {
    interval = intersectsp_ray_aabb(r, b);
    if interval {
        extract = *interval;
        return extract.high;
    }
    return inf;
}

func distmin(r : Ray, b : AABB) -> Float {
    interval = intersectsp_ray_aabb(r, b);
    if interval {
        extract = *interval;
        return extract.low;
    }
    return -inf;
}

element TriangleIntersection {
    b0, b1, b2, t : Float;
}

// pstd::optional<TriangleIntersection> IntersectTriangle
// shapes.cpp
// TODO: need special intrinsic parsing!
func intersectsp_ray_tri(ray : Ray, tri : Triangle) -> option[TriangleIntersection] {
    // Return no intersection if triangle is degenerate
    if (sqlen(cross_(tri.p2 - tri.p0, tri.p1 - tri.p0)) == 0)
        return {};

    // Transform triangle vertices to ray coordinate space
    // Translate vertices based on ray origin
    p0t : mut = tri.p0 - ray.o;
    p1t : mut = tri.p1 - ray.o;
    p2t : mut = tri.p2 - ray.o;

    // Permute components of triangle vertices and ray direction
    kz : u32 = idxmax(abs(ray.d));
    kx = (kz + 1) % 3;
    ky = (kx + 1) % 3;
    d = permute(ray.d, {kx, ky, kz});
    p0t = permute(p0t, {kx, ky, kz});
    p1t = permute(p1t, {kx, ky, kz});
    p2t = permute(p2t, {kx, ky, kz});

    // Apply shear transformation to translated vertex positions
    Sx = -d.x / d.z;
    Sy = -d.y / d.z;
    Sz = 1 / d.z;
    p0t.x += Sx * p0t.z;
    p0t.y += Sy * p0t.z;
    p1t.x += Sx * p1t.z;
    p1t.y += Sy * p1t.z;
    p2t.x += Sx * p2t.z;
    p2t.y += Sy * p2t.z;

    // Compute edge function coefficients _e0_, _e1_, and _e2_
    // TODO: understand what that function is doing
    // e0 = DifferenceOfProducts(p1t.x, p2t.y, p1t.y, p2t.x);
    // e1 = DifferenceOfProducts(p2t.x, p0t.y, p2t.y, p0t.x);
    // e2 = DifferenceOfProducts(p0t.x, p1t.y, p0t.y, p1t.x);
    e0 = p1t.x * p2t.y - p1t.y * p2t.x;
    e1 = p2t.x * p0t.y - p2t.y * p0t.x;
    e2 = p0t.x * p1t.y - p0t.y * p1t.x;

    // TODO: Fall back to double-precision test at triangle edges
    // if (sizeof(Float) == sizeof(float) && (e0 == 0.0f || e1 == 0.0f || e2 == 0.0f)) { ... }

    // Perform triangle edge and determinant tests
    if ((e0 < 0 || e1 < 0 || e2 < 0) && (e0 > 0 || e1 > 0 || e2 > 0))
        return {};
    det = e0 + e1 + e2;
    if (det == 0)
        return {};

    // Compute scaled hit distance to triangle and test against ray $t$ range
    p0t.z *= Sz;
    p1t.z *= Sz;
    p2t.z *= Sz;

    tScaled = e0 * p0t.z + e1 * p1t.z + e2 * p2t.z;
    if (det < 0 && (tScaled >= 0 || tScaled < ray.t * det))
        return {};
    else if (det > 0 && (tScaled <= 0 || tScaled > ray.t * det))
        return {};

    // Compute barycentric coordinates and $t$ value for triangle intersection
    invDet = 1 / det;
    b0 = e0 * invDet;
    b1 = e1 * invDet;
    b2 = e2 * invDet;
    t = tScaled * invDet;
    // DCHECK(!IsNaN(t));

    // Ensure that computed triangle $t$ is conservatively greater than zero
    // Compute $\delta_z$ term for triangle $t$ error bounds
    maxZt = max(abs(vec3f{p0t.z, p1t.z, p2t.z}));
    deltaZ = gamma(3) * maxZt;

    // Compute $\delta_x$ and $\delta_y$ terms for triangle $t$ error bounds
    maxXt = max(abs(vec3f{p0t.x, p1t.x, p2t.x}));
    maxYt = max(abs(vec3f{p0t.y, p1t.y, p2t.y}));
    deltaX = gamma(5) * (maxXt + maxZt);
    deltaY = gamma(5) * (maxYt + maxZt);

    // Compute $\delta_e$ term for triangle $t$ error bounds
    deltaE = 2 * (gamma(2) * maxXt * maxYt + deltaY * maxXt + deltaX * maxYt);

    // Compute $\delta_t$ term for triangle $t$ error bounds and check _t_
    maxE = max(abs(vec3f{e0, e1, e2}));
    deltaT = 3 * (gamma(3) * maxE * maxZt + deltaE * maxZt + deltaZ * maxE) * abs(invDet);
    if (t <= deltaT)
        return {};

    // Return _TriangleIntersection_ for intersection
    return TriangleIntersection{b0, b1, b2, t};   
}

func intersects(ray : Ray, tri : Triangle) -> bool {
    return cast[[bool]](intersectsp_ray_tri(ray, tri));
}

func distmin(ray : Ray, tri : Triangle) -> Float {
    isect = intersectsp_ray_tri(ray, tri);
    if isect {
        // TODO(ajr): this is annoying syntax. Fix.
        isect_ = *isect;
        return isect_.t;
    } else {
        return inf;
    }
}
