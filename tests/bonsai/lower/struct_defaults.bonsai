element vec3f = vector[f32, 3];

element Ray {
    o : vec3f;
    d : vec3f;
    t : f32 = 0;
}

func build_ray() = Ray{};

func build_ray_params(o : vec3f, d : vec3f, t : f32) = Ray{o, d, t};

// TODO: get this working. Need IR changes.
