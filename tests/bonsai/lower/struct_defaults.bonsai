// TODO: get this working. Need parser and IR support.
// func build_ray_params2(o : vec3f, d : vec3f) = Ray{.o = o, .d = d};

element Ray1 {
    o : vec3f;
    d : vec3f;
    t : f32 = 1;
}

func build_ray1() = Ray1{};

element Ray2 {
    o, d : vec3f = 1;
    t : f32 = 1;
}

func build_ray2() = Ray2{};

element Ray3 {
    o = 0, d = 1 : vec3f;
    t : f32 = 1;
}

func build_ray3() = Ray3{};
