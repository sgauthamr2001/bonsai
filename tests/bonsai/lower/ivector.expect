type vec2bf16 = bf16x2
type vec2f99 = f9_9x2
type vec2h = f16x2
type vec4 = f32x4

func __fma__bf16_bf16x2(a : bf16x2, b : bf16x2, c : bf16x2) -> bf16x2 {
  return (a * b) + c
}

func __fma__f16_f16x2(a : f16x2, b : f16x2, c : f16x2) -> f16x2 {
  return (a * b) + c
}

func __fma__f32_f32x4(a : f32x4, b : f32x4, c : f32x4) -> f32x4 {
  return (a * b) + c
}

func __fma__f9_9_f9_9x2(a : f9_9x2, b : f9_9x2, c : f9_9x2) -> f9_9x2 {
  return (a * b) + c
}

func fma_x2bf16_(a : bf16x2, b : bf16x2, c : bf16x2) -> bf16x2 {
  return __fma__bf16_bf16x2(a, b, c)
}

func fma_x2f99_(a : f9_9x2, b : f9_9x2, c : f9_9x2) -> f9_9x2 {
  return __fma__f9_9_f9_9x2(a, b, c)
}

func fma_x2h_(a : f16x2, b : f16x2, c : f16x2) -> f16x2 {
  return __fma__f16_f16x2(a, b, c)
}

func fma_x4_(a : f32x4, b : f32x4, c : f32x4) -> f32x4 {
  return __fma__f32_f32x4(a, b, c)
}

func foo(a : f32x4) -> f32x4 {
  return fma_x4_(a, a, a)
}

func foo_typed(a : f32x4) -> f32x4 {
  return fma_x4_(a, a, a)
}


