//! flags: -b llvm -e

func mutate0(i : mut array[i32, 4]) {
   i[0] = 2;
   return;
}

func test_a() {
    a : mut array[i32, 4] = {1, 2, 3, 4};
    print(a);
    mutate0(a);
    print(a);
    return;
}

element Example {
    x : i32;
    y : i32;
}

func mutate1(i : mut Example) {
   i.y = i.x;
   i.x = 4;
   return;
}

func test_b() {
    b : mut Example = {1, 2};
    print(b);
    b.y = 13;
    print(b);
    mutate1(b);
    print(b);
    return;
}

element Example1 {
    a : array[i32, 4];
    b : i32;
}

func mutate2(i : mut Example1) {
    i.b = 2;
    i.a[0] = 4;
    return;
}

func test_c() {
    a : mut array[i32, 4] = {1, 2, 3, 4};
    c : mut Example1 = {a, 3};
    print(c);
    mutate2(c);
    print(c);
    return;
}

func mutate3(i : mut i32) {
    i = 10;
    return;
}

func test_d() {
    a : mut i32 = 4;
    print(a);
    mutate3(a);
    print(a);
    return;
}

element Example2 {
    e : Example1;
    b : i32;
}


func mutate4(i : mut Example2) {
    i.b = i.e.b + i.e.a[0];
    // TODO: fix type inf + parsing on this.
    // i.e.a = array[i32, 4]{7, 8, 9, 10};
    temp : mut array[i32, 4] = {7, 8, 9, 10};
    i.e.a = temp;
    return;
}

func test_e() {
    a : mut array[i32, 4] = {1, 2, 3, 4};
    c : mut Example1 = {a, 3};
    e : mut Example2 = {c, 9};
    print(e);
    mutate4(e);
    print(e);
    print(a);
    return;
}

func mutate5(i : mut Example1) {
    i.b += 4;
    i.a[0] += i.a[1];
    return;
}

func test_f() {
    a : mut array[i32, 4] = {1, 2, 3, 4};
    c : mut Example1 = {a, 3};
    print(c);
    mutate5(c);
    print(c);
    print(a);
    return;
}

// TODO(ajr): figure out expected behavior of this?
func test_TODO() {
    a : array[i32, 4] = {1, 2, 3, 4};
    c : mut Example1 = {a, 3};
    print(c);
    mutate2(c);
    print(c);
    return;
}

func main() -> i32 {
    test_a();
    test_b();
    test_c();
    test_d();
    test_e();
    test_f();
    return 0;
}
