//! flags: -b llvm -e

// Just an abs(), used to test control flow.
func foo(x : i32) -> i32 {
    if x < 0 {
        return -x;
    }
    return x;
}

func array_abs(a : array[i32, 8]) = map(foo, a);

func main() -> i32 {
    xs : array[i32, 8] = {-1, 1, 2, -2, -214, 365, 12, -2147483647};
    print(xs);
    abs_xs = array_abs(xs);
    print(abs_xs);
    return 0;
}
