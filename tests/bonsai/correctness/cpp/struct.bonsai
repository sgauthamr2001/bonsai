//! flags: -b cpp -o tests/bonsai/correctness/cpp/struct
//! commands: clang++ -c $<>/main_struct.cpp -o $<>/main_struct.o, clang++ $<>/main_struct.o $<>/struct.o -o $<>/struct, ./$<>/struct, rm $<>/struct, rm $<>/main_struct.o, rm $<>/struct.h, rm $<>/struct.o
element Position { x: i32; y: i32; }

func [[export]] add(i: Position, j: Position) -> Position {
    return Position {i.x + j.x, i.y + j.y };
}
