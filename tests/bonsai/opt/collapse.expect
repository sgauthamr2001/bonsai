func _traverse_array0(m : i32, n : i32, a : f32[n][m]) -> f32[n][m] {
  alloc _alloc0 : mut f32[m * n]
  forall _i0 in [0:m:1] {
    forall _i1 in [0:n:1] {
      _alloc0[(_i0 * n) + _i1] = sqrt(a[_i0][_i1])
    }
  }
  return reinterpret_cast<f32[n][m]>((*_alloc0))
}

func _traverse_array1(m : i32, n : i32, a : f32[n][m]) -> f32[n][m] {
  alloc _alloc1 : mut f32[m * n]
  forall _i_a in [0:m * n:1] {
    let _i0 = _i_a / n in
    let _i1 = _i_a % n in
    _alloc1[(_i0 * n) + _i1] = sqrt(a[_i0][_i1])
  }
  return reinterpret_cast<f32[n][m]>((*_alloc1))
}

func _traverse_array2(a : f32[8][32]) -> f32[8][32] {
  alloc _alloc2 : mut f32[32 * 8]
  forall _i_b in [0:256:1] {
    let _i0 = _i_b / 8 in
    let _i1 = _i_b & 7 in
    _alloc2[(_i0 << 3) + _i1] = sqrt(a[_i0][_i1])
  }
  return reinterpret_cast<f32[8][32]>((*_alloc2))
}

func _traverse_array3(h : i32, w : i32) -> i32[h][w] {
  alloc _alloc3 : mut i32[w * h]
  forall _i_c in [0:w * h:1] {
    let _i0 = _i_c / h in
    let _i1 = _i_c % h in
    _alloc3[(_i0 * h) + _i1] = f(_i0, _i1)
  }
  return reinterpret_cast<i32[h][w]>((*_alloc3))
}

func _traverse_array4(w : i32) -> i32[w] {
  alloc _alloc4 : mut i32[w]
  forall _i in [0:((w + 3) / 4) << 2:1] {
    let _io = (_i / 4) << 2 in
    let _ii = _i & 3 in
    if (_io < w) {
      if (_ii < 4) {
        _alloc4[_io + _ii] = f(_io + _ii, 1)
      }
    }
  }
  return (*_alloc4)
}

func f(x : i32, y : i32) -> i32 {
  print(x, y)
  return x + y
}

func no_collapse(n : i32, m : i32, a : f32[n][m]) -> f32[n][m] {
  return _traverse_array0(m, n, a)
}

func process1(n : i32, m : i32, a : f32[n][m]) -> f32[n][m] {
  return _traverse_array1(m, n, a)
}

func process2(a : f32[8][32]) -> f32[8][32] {
  return _traverse_array2(a)
}

func process3(w : i32, h : i32) -> i32[h][w] {
  return _traverse_array3(h, w)
}

func process4(w : i32) -> i32[w] {
  return _traverse_array4(w)
}


