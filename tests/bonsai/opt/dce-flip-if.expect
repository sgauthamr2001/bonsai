func bar(i : i32x8) -> u32x8 {
  if (0 < reduce<+>(i)) {
    let j = foo(i) in
  } else {
    print(i)
  }
  return abs(i)
}

func bazz(i : i32) -> i32 {
  j := i + 1
  if (0 < i) {
    let _unused0 = print_and_return(j) in
  }
  return cast<i32>(abs(i))
}

func fizz(i : i32) -> i32 {
  if (0 < i) {
    let _unused0 = cast<i32>(reduce<+>(foo(i32x8(-4)))) in
  } else {
    print(i)
  }
  return cast<i32>(abs(i))
}

func foo(i : i32x8) -> u32x8 {
  if (!(0 < reduce<+>(i))) {
    print(i)
  }
  return abs(i)
}

func main() -> i32 {
  let j = fizz(-1) in
  let k = fizz(12) in
  return cast<i32>(reduce<+>(bar(i32x8(-1))))
}

func print_and_return(i : i32) -> i32 {
  print(i)
  return i
}


