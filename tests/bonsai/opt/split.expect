func _traverse_array0(n : i32, a : f32[n]) -> f32[n] {
  alloc _alloc0 : mut f32[n]
  forall _io in [0:n:16] {
    forall _ii in [0:16:1] {
      _alloc0[_io + _ii] = sqrt(a[_io + _ii])
    }
  }
  return (*_alloc0)
}

func process(n : i32, a : f32[n]) -> f32[n] {
  return _traverse_array0(n, a)
}


