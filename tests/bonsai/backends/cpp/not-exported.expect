; Function Attrs: mustprogress nofree norecurse nosync nounwind willreturn memory(argmem: readwrite)
define void @id(ptr nocapture noundef nonnull writeonly %_ret0, ptr nocapture noundef nonnull readonly %g) local_unnamed_addr #2 {
id_entry:
  %0 = load <2 x i32>, ptr %g, align 4
  store <2 x i32> %0, ptr %_ret0, align 4
  ret void
}

