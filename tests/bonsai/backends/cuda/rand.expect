#include "runtime/CUDA/math.h"

__device__ float d_plus_rand(float x, curandState* _rng_state) {
  if (x == 0) {
    return 0;
  }
  return (x + curand_uniform(_rng_state));
}

__device__ float f4(float x) {
  if ((float)42 < x) {
    return (float)-1;
  }
  return 1;
}

__device__ float f3(float x, curandState* _rng_state) {
  if ((curand_uniform(_rng_state) + 1) < x) {
    return (float)42;
  }
  return f4(x);
}

__device__ float f2(float x, curandState* _rng_state) {
  if (x == curand_uniform(_rng_state)) {
    return d_plus_rand(x, _rng_state);
  }
  return f3(x, _rng_state);
}

__global__ void f1(float* x) {
  curandState _rng_state;
  curand_init(idx, 0, 0, &_rng_state);
  if ((*x) == 1) {
    *x = 0;
  } else {
    *x += f2((*x), (&_rng_state));
  }
}

__host__ float h_plus_rand(float x) {
  if (x == 0) {
    return 0;
  }
  return (x + random<float>());
}

__host__ int32_t main(float input) {
  float _x = input;
  float* x = &_x;
  f1(x);
  if ((*x) == random<float>()) {
    return 0;
  }
  return (int32_t)h_plus_rand(input);
}
