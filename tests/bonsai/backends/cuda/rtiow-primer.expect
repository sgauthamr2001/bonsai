#include <cuda_fp16.h>
#include <math.h>
#include "runtime/CUDA/math.h"

struct FInterval {
  float low;
  float high;
};

struct Ray {
  float3 o;
  float3 d;
  float tmax = INFINITY;
};

struct Sphere {
  float3 center;
  float radius;
};

struct _option0 {
  FInterval value;
  bool set = false;
};

struct hit_record {
  float3 p;
  float3 normal;
  float t;
  bool front_face;
};

float3 at(const Ray* r, float t) {
  return ((*r).o + (make_float3(t) * (*r).d));
}

_option0 intersectsp_ray_sphere(const Ray* r, const Sphere* s) {
  float3 oc = ((*s).center - (*r).o);
  const float h = dot((*r).d, oc);
  const float disc = ((h * h) - 1);
  if (disc < 0) {
    return _option0{};
  }
  const float sqrtd = sqrt(disc);
  const float root0 = (h - sqrtd);
  const float root1 = (h + sqrtd);
  const FInterval interval = FInterval{min(root0, root1), max(root0, root1)};
  return _option0{interval, true};
}

float distmin_Ray_Sphere(const Ray* r, const Sphere* s) {
  const _option0 interval = intersectsp_ray_sphere(r, s);
  if (interval.set) {
    const FInterval extract = interval.value;
    return extract.low;
  }
  return -INFINITY;
}

hit_record get_hit_record(const Ray* r, const Sphere* s) {
  const float t = distmin_Ray_Sphere(r, s);
  float3 p = ((*r).o + (make_float3(t) * (*r).d));
  float3 outward_normal = ((p - (*s).center) / make_float3((*s).radius));
  const bool front_face = (dot((*r).d, outward_normal) < 0);
  float3 normal = (front_face ? outward_normal : -outward_normal);
  const hit_record record = hit_record{p, normal, t, front_face};
  return record;
}
