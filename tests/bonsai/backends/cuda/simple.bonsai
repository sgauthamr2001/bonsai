//! flags: -b cuda

element Inner { x: i32; y: i32; z: i32; }
element Outer { f: f32; position: Inner; }

element Foo {
    x: i32 = 42;
    a: array[i32, 2];
}

func add_s(x: i32, y: i32) {
    v: i32 = x + y;
    w: mut i32 = 1;
    w = 2;
    return v + w;
}

func add_v(x: vector[i32, 4], y: vector[i32, 4]) -> vector[i32, 4] {
    v: vector[i32, 4] = x + y;
    w: vector[i32, 4] = select(x < y, x, y);
    return v + w;
}

func select_v(x: vector[i32, 3], y: vector[i32, 3]) -> vector[i32, 3] {
    invDir = 1 / x;
    dirIsNeg: vector[bool, 3] = invDir < 0;

    s: vector[i32, 3] = select(dirIsNeg, x, y);
    return s;
}

func if_else(x: f32, y: f32) -> i32 {
    v: vector[f32, 3] = {x, y, 1.0};
    if (v.x > v.z + v.y) {
        return 0; 
    } else { 
        return select((v.x + v.y) > 0, 1, 2);
    }
}
