//! flags: -b cuda

element Inner { x: i32; y: i32; z: i32; }
element Outer { f: f32; position: Inner; }

element Foo {
    x: i32 = 42;
}

func add_s(x: i32, y: i32) {
    v: i32 = x + y;
    return v;
}


func add_v(x: vector[i32, 4], y: vector[i32, 4]) -> vector[i32, 4] {
    v: vector[i32, 4] = x + y;
    return v;
}

func if_else(x: f32, y: f32) -> i32 {
    v: vector[f32, 3] = {x, y, 1.0};
    if (v.x > v.z + v.y) {
        return 0; 
    } else { 
        return select((v.x + v.y) > 0, 1, 2);
    }
}
