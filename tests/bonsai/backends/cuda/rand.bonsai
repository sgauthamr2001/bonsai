//! flags: -b cuda

// Support rand that is used on both host and device.
func plus_rand(x: f32) -> f32 {
    if (x == 0) { return 0; }
    return x + rand();
}

func f4(x: f32) -> f32 {
    if (x > 42) { return -1; }
    return 1;
}

func f3(x: f32) -> f32 {
    if (x > rand() + 1) { return 42; }
    return f4(x);
}

func f2(x: f32) -> f32 {
    if (x == rand()) { return plus_rand(x); }
    return f3(x);
}

func [[kernel]] f1(x: mut f32) -> void  {
  tid: i32 = 42 + x;
  if (x == 1.0) { 
    x = cast[[f32]](tid); 
  } else {
    x += f2(x);
  }
}

func [[export]] main(input: f32) -> i32 {
    x: mut f32 = input;
    f1(x);
    if (x == rand()) { return 0; }
    return plus_rand(input);
}
