; ModuleID = 'bonsai_module'
source_filename = "bonsai_module"

%struct.__dyn_array0 = type { ptr, i32, i32, <64 x i8> }

define i32 @main() {
main_entry:
  %x = alloca %struct.__dyn_array0, align 64
  %x.buffer_untyped = tail call ptr @malloc(i64 4)
  %x.buffer_ptr = getelementptr inbounds %struct.__dyn_array0, ptr %x, i32 0, i32 0
  store ptr %x.buffer_untyped, ptr %x.buffer_ptr, align 8
  %x.size_ptr = getelementptr inbounds %struct.__dyn_array0, ptr %x, i32 0, i32 1
  store atomic i32 0, ptr %x.size_ptr release, align 4
  %x.capacity_ptr = getelementptr inbounds %struct.__dyn_array0, ptr %x, i32 0, i32 2
  store atomic i32 1, ptr %x.capacity_ptr release, align 4
  %x.mutex_ptr = getelementptr inbounds %struct.__dyn_array0, ptr %x, i32 0, i32 3
  %0 = call i32 @pthread_mutex_init(ptr %x.mutex_ptr, ptr null)
  %x.size_ptr1 = getelementptr inbounds %struct.__dyn_array0, ptr %x, i32 0, i32 1
  %1 = atomicrmw add ptr %x.size_ptr1, i32 1 acq_rel, align 4
  %x.capacity_ptr2 = getelementptr inbounds %struct.__dyn_array0, ptr %x, i32 0, i32 2
  %x.mutex_ptr3 = getelementptr inbounds %struct.__dyn_array0, ptr %x, i32 0, i32 3
  %x.buffer_ptr4 = getelementptr inbounds %struct.__dyn_array0, ptr %x, i32 0, i32 0
  %x.capacity = load atomic i32, ptr %x.capacity_ptr2 acquire, align 4
  %index-ge-capacity = icmp uge i32 %1, %x.capacity
  br i1 %index-ge-capacity, label %lock-mutex, label %continue

lock-mutex:                                       ; preds = %main_entry
  %2 = call i32 @pthread_mutex_lock(ptr %x.mutex_ptr3)
  %x.capacity5 = load atomic i32, ptr %x.capacity_ptr2 acquire, align 4
  %index-ge-capacity6 = icmp uge i32 %1, %x.capacity5
  br i1 %index-ge-capacity6, label %grow, label %unlock-mutex

continue:                                         ; preds = %unlock-mutex, %main_entry
  %3 = call i32 @pthread_mutex_lock(ptr %x.mutex_ptr3)
  %deref_temp7 = load %struct.__dyn_array0, ptr %x, align 64
  %buffer8 = extractvalue %struct.__dyn_array0 %deref_temp7, 0
  %4 = getelementptr inbounds i32, ptr %buffer8, i32 %1
  store i32 0, ptr %4, align 4
  %5 = call i32 @pthread_mutex_unlock(ptr %x.mutex_ptr3)
  %deref_temp9 = load %struct.__dyn_array0, ptr %x, align 64
  %buffer10 = extractvalue %struct.__dyn_array0 %deref_temp9, 0
  %extract_ptr = getelementptr inbounds i32, ptr %buffer10, i32 0
  %extract = load i32, ptr %extract_ptr, align 4
  ret i32 %extract

grow:                                             ; preds = %lock-mutex
  %6 = icmp eq i32 %x.capacity5, 0
  %7 = mul i32 %x.capacity5, 2
  %x.new-capacity = select i1 %6, i32 1, i32 %7
  %8 = zext i32 %x.new-capacity to i64
  %deref_temp = load %struct.__dyn_array0, ptr %x, align 64
  %buffer = extractvalue %struct.__dyn_array0 %deref_temp, 0
  %9 = mul i64 %8, 4
  %10 = call ptr @realloc(ptr %buffer, i64 %9)
  store ptr %10, ptr %x.buffer_ptr4, align 8
  %11 = trunc i64 %8 to i32
  store atomic i32 %11, ptr %x.capacity_ptr2 release, align 4
  br label %unlock-mutex

unlock-mutex:                                     ; preds = %grow, %lock-mutex
  %12 = call i32 @pthread_mutex_unlock(ptr %x.mutex_ptr3)
  br label %continue
}

declare noalias ptr @malloc(i64)

declare i32 @pthread_mutex_init(ptr, ptr)

declare i32 @pthread_mutex_lock(ptr)

declare ptr @realloc(ptr, i64)

declare i32 @pthread_mutex_unlock(ptr)
