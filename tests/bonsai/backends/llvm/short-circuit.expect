; ModuleID = 'bonsai_module'
source_filename = "bonsai_module"

; Function Attrs: mustprogress nofree norecurse nosync nounwind willreturn memory(argmem: read)
define range(i32 1, 3) i32 @check0(i32 noundef %a, ptr nocapture noundef readonly %b) local_unnamed_addr #0 {
check0_entry:
  %0 = icmp sgt i32 %a, -1
  br i1 %0, label %and_rhs, label %next_bb

common.ret:                                       ; preds = %and_rhs, %next_bb
  %common.ret.op = phi i32 [ 2, %next_bb ], [ 1, %and_rhs ]
  ret i32 %common.ret.op

next_bb:                                          ; preds = %and_rhs, %check0_entry
  br label %common.ret

and_rhs:                                          ; preds = %check0_entry
  %1 = zext nneg i32 %a to i64
  %extract_ptr = getelementptr float, ptr %b, i64 %1
  %extract = load float, ptr %extract_ptr, align 4
  %2 = fcmp olt float %extract, 0.000000e+00
  br i1 %2, label %common.ret, label %next_bb
}

; Function Attrs: mustprogress nofree norecurse nosync nounwind willreturn memory(argmem: read)
define range(i32 1, 3) i32 @check1(i32 noundef %a, ptr nocapture noundef readonly %b) local_unnamed_addr #0 {
check1_entry:
  %0 = icmp slt i32 %a, 0
  br i1 %0, label %common.ret, label %or_rhs

common.ret:                                       ; preds = %check1_entry, %or_rhs, %next_bb
  %common.ret.op = phi i32 [ 2, %next_bb ], [ 1, %or_rhs ], [ 1, %check1_entry ]
  ret i32 %common.ret.op

next_bb:                                          ; preds = %or_rhs
  br label %common.ret

or_rhs:                                           ; preds = %check1_entry
  %1 = zext nneg i32 %a to i64
  %extract_ptr = getelementptr float, ptr %b, i64 %1
  %extract = load float, ptr %extract_ptr, align 4
  %2 = fcmp olt float %extract, 0.000000e+00
  br i1 %2, label %common.ret, label %next_bb
}

; Function Attrs: mustprogress nofree norecurse nosync nounwind willreturn memory(argmem: read)
define float @check2_noshortcircuit(i32 noundef %a, ptr nocapture noundef readonly %b) local_unnamed_addr #0 {
check2_noshortcircuit_entry:
  %or.cond = icmp ult i32 %a, 5
  br i1 %or.cond, label %then_bb, label %common.ret

common.ret:                                       ; preds = %check2_noshortcircuit_entry, %then_bb
  %common.ret.op = phi float [ %extract, %then_bb ], [ -1.000000e+00, %check2_noshortcircuit_entry ]
  ret float %common.ret.op

then_bb:                                          ; preds = %check2_noshortcircuit_entry
  %0 = zext nneg i32 %a to i64
  %extract_ptr = getelementptr float, ptr %b, i64 %0
  %extract = load float, ptr %extract_ptr, align 4
  br label %common.ret
}

attributes #0 = { mustprogress nofree norecurse nosync nounwind willreturn memory(argmem: read) }
