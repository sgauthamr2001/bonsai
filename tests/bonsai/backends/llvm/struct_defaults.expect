; Function Attrs: mustprogress nofree norecurse nosync nounwind willreturn memory(none)
define %Ray @build_ray_params3(float %oall, float %dall) local_unnamed_addr #0 {
build_ray_params3_entry:
  %.splatinsert = insertelement <3 x float> poison, float %oall, i64 0
  %.splat = shufflevector <3 x float> %.splatinsert, <3 x float> poison, <3 x i32> zeroinitializer
  %.splatinsert1 = insertelement <3 x float> poison, float %dall, i64 0
  %.splat2 = shufflevector <3 x float> %.splatinsert1, <3 x float> poison, <3 x i32> zeroinitializer
  %0 = insertvalue %Ray poison, <3 x float> %.splat, 0
  %1 = insertvalue %Ray %0, <3 x float> %.splat2, 1
  %2 = insertvalue %Ray %1, float 0.000000e+00, 2
  ret %Ray %2
}

