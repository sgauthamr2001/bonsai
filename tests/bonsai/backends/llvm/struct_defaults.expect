; Function Attrs: mustprogress nofree norecurse nosync nounwind willreturn memory(none)
define %Ray @build_ray_params(<3 x float> %o, <3 x float> %d, float %t) local_unnamed_addr #0 {
build_ray_params_entry:
  %0 = insertvalue %Ray poison, <3 x float> %o, 0
  %1 = insertvalue %Ray %0, <3 x float> %d, 1
  %2 = insertvalue %Ray %1, float %t, 2
  ret %Ray %2
}

