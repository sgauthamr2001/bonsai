//! flags: -b llvm

func _fma<F : IFloat, V : IVector[[F]]>(a : V, b : V, c : V) -> V {
    return a * b + c;
}

element vec4 = vector[f32, 4];
element vec2h = vector[f16, 2];

func _fma_x4(a : vec4, b : vec4, c : vec4) = _fma[[f32, vec4]](a, b, c);

// Use _fma_x4 to make sure type inference works through generics
func foo(a : vec4) = _fma_x4(a, a, a);

func foo_typed(a : vec4) -> vec4 = _fma_x4(a, a, a);

// Try a different instantiation
func _fma_x2h(a : vec2h, b : vec2h, c : vec2h) = _fma[[f16, vec2h]](a, b, c);

// TODO: allow implicit template parameters (via inference).
// func _fma_x2_v2(a : vector[f32, 2], b : vector[f32, 2], c : vector[f32, 2]) = _fma(a, b, c);
// func _fma_x3(a : vector[f32, 3], b : vector[f32, 3], c : vector[f32, 3]) = _fma(a, b, c);
