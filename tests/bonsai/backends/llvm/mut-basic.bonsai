//! flags: -b llvm

element i32x2 = array[i32, 2];

element Example {
    x : i32;
    y : i32x2;
}

func write_x(e : mut Example) {
    e.x = 3;
    return;
}

func write_z(z : mut i32x2) {
    z[1] = 3;
    return;
}

func write_y(e : mut Example) {
    e.y[0] = 3;
    return;
}

func write_w(e : mut array[Example, 2]) {
    e[0] = {1, i32x2{2, 3}};
    return;
}
