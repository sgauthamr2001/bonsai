// -b llvm

element vec3f = vector[f32, 3];

element Ray {
    o : vec3f;
    d : vec3f;
    t : f32 = 0;
}

func build_ray() = Ray{};

func build_ray_params(o : vec3f, d : vec3f, t : f32) = Ray{o, d, t};

// Tests default parameter build.
func build_ray_params1(o : vec3f, d : vec3f) = Ray{o, d};

// Tests named struct build
func build_ray_params2(o : vec3f, d : vec3f) = Ray{.o = o, .d = d};

// Tests constant casting through struct building.
func build_ray_params3(oall : f32, dall : f32) = Ray{.o = oall, .d = dall};

element Ray1 {
    o : vec3f;
    d : vec3f;
    t : f32 = 1;
}

func build_ray1() = Ray1{};

element Ray2 {
    o, d : vec3f = 1;
    t : f32 = 1;
}

func build_ray2() = Ray2{};

element Ray3 {
    o = 0, d = 1 : vec3f;
    t : f32 = 1;
}

func build_ray3() = Ray3{};
